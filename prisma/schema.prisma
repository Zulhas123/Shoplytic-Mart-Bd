generator client {
  provider = "prisma-client-js"
  engineType = "binary"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  ADMIN
}

enum OrderStatus {
  PENDING
  CONFIRMED
  REJECTED
  PAID
  SHIPPED
  DELIVERED
  CANCELED
}

enum PaymentMethod {
  BKASH
  NAGAD
  MANUAL
}

enum DeliveryAgentStatus {
  ACTIVE
  INACTIVE
}

enum DeliveryStatus {
  ASSIGNED
  PENDING
  COMPLETED
  CANCELED
}

enum DeliveryPaymentStatus {
  UNPAID
  PAID
  COD
}

model User {
  id           String   @id @default(cuid())
  email        String?  @unique
  passwordHash String
  name         String   @unique
  address      String?
  role         UserRole @default(USER)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  orders Order[]
}

model Category {
  id        String    @id @default(cuid())
  name      String    @unique
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  products Product[]
}

model Product {
  id          String   @id @default(cuid())
  name        String
  description String
  priceCents  Int
  imageUrl    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  categoryId String?
  category   Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  orderItems OrderItem[]

  @@index([categoryId])
}

model Order {
  id               String      @id @default(cuid())
  userId           String?
  guestKey         String?
  status           OrderStatus @default(PENDING)
  paymentMethod    PaymentMethod?
  paymentReference String?
  paidAt           DateTime?
  shippingName     String
  shippingEmail    String?
  shippingPhone    String?
  shippingAddress1 String
  shippingAddress2 String?
  shippingCity     String
  shippingPostal   String
  totalCents       Int
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  user  User?       @relation(fields: [userId], references: [id], onDelete: SetNull)
  items OrderItem[]
  delivery Delivery?

  @@index([userId])
  @@index([guestKey])
}

model OrderItem {
  id         String  @id @default(cuid())
  orderId    String
  productId  String
  name       String
  priceCents Int
  quantity   Int

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@index([orderId])
  @@index([productId])
}

model DeliveryAgent {
  id           String              @id @default(cuid())
  name         String
  phone        String              @unique
  address      String
  vehicleType  String
  deliveryZone String
  status       DeliveryAgentStatus @default(ACTIVE)
  joinedAt     DateTime            @default(now())
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  deliveries Delivery[]
}

model Delivery {
  id                 String                @id @default(cuid())
  orderId             String                @unique
  agentId             String
  status              DeliveryStatus        @default(ASSIGNED)
  paymentStatus       DeliveryPaymentStatus @default(UNPAID)
  deliveryChargeCents Int                   @default(0)
  totalAmountCents    Int
  deliveredAt         DateTime?
  canceledAt          DateTime?
  deliveryDate        DateTime?
  customerSnapshot    Json
  itemsSnapshot       Json
  categoryBreakdown   Json
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  agent DeliveryAgent @relation(fields: [agentId], references: [id], onDelete: Restrict)

  @@index([agentId])
  @@index([status])
  @@index([paymentStatus])
}
